# Environment Configuration Template
# Copy this file to .env and fill in your actual API keys
# IMPORTANT: .env is in .gitignore and should NEVER be committed to Git

# Mistral AI API Key
# Get your key from: https://console.mistral.ai/keys
MISTRAL_API_KEY="your_mistral_api_key_here"

# Whisper Model Size
# Options: tiny, base, small, medium, large
# tiny = fastest, base = recommended, small/medium/large = more accurate but slower
WHISPER_MODEL="base"

# Sarvam AI API Key (for Hindi/Hinglish transcription)
# Get your key from: https://console.sarvam.ai
SARVAM_API_KEY="your_sarvam_api_key_here"

# Sarvam STT Model
# Usually: saaras:v2.5
SARVAM_STT_MODEL="saaras:v2.5"
